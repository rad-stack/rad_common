.card
  .card-header
    .d-flex.justify-content-between.align-items-center
      %h5.mb-0= "Conversation with #{@direct_message.other_user(current_user)}"
      = link_to 'Back', direct_messages_path, class: 'btn btn-secondary btn-sm'
  .card-body.bg-secondary.bg-opacity-25.p-0.d-flex.flex-column{ style: 'height: 70vh;' }
    .flex-grow-1.chat-scroll-panel#scroll-container
      .chat-container.mt-3
        %ul.chat-box.chatContainerScroll{ id: dom_id(@direct_message, 'chat') }
          = render 'direct_messages/chat_messages', direct_message: @direct_message
          = turbo_stream_from @direct_message

    .border-top.pt-3.pb-4.px-4.bg-white
      = turbo_frame_tag 'chat-form' do
        = simple_form_for @direct_message,
                          url: rad_chat_message_path(chattable_type: @direct_message.class.name, chattable_id: @direct_message.id),
                          method: :patch,
                          html: { data: { controller: 'llm-chat-form', 'llm-chat-form-target': 'form' } } do |f|
          .card
            .card-body
              .row
                .col-12
                  .d-flex.flex-row
                    .input-group
                      %input.form-control.ays-ignore{ name: 'current_message',
                                                      placeholder: 'Type a message...',
                                                      type: 'text',
                                                      id: 'chat_current_message',
                                                      data: { 'llm-chat-form-target': 'currentMessage' } }
                      = f.button :button, type: :submit, class: 'btn btn-secondary', id: 'chat-submit-btn' do
                        = icon('paper-plane')
                      = f.button :button, type: :button, class: 'btn btn-secondary dropdown-toggle no-caret',
                                          'data-bs-toggle': 'dropdown' do
                        = '...'
                      %ul.dropdown-menu
                        %li
                          = f.button :button, name: 'reset_chat', value: 'reset' do
                            = icon('comment-slash', 'Clear Chat?')
