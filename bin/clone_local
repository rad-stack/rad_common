#!/usr/bin/env ruby
require 'optparse'
require_relative 'rad_bin'
require_relative '../app/services/heroku_commands'

def additional_excluded_tables
  config = YAML.load_file('config/rad_common.yml', aliases: true)
  env = ENV['RAILS_ENV'] || 'development'
  config.dig(env, 'clone_local_exclude') || []
end

def profile_description(base_tables, extra_tables, label)
  all_tables = (base_tables + extra_tables).uniq

  return "#{label} (include all tables)" if all_tables.empty?

  "#{label} (excludes #{all_tables.join(', ')})"
end

def run_interactive_clone(backup_option)
  prompt = TTY::Prompt.new

  restore_source = prompt.select('How would you like to restore your database?') do |menu|
    menu.choice 'From a remote Heroku backup', :remote
    menu.choice 'From a local backup file (/heroku_backups)', :local
  end

  extra = additional_excluded_tables
  excluded = HerokuCommands::EXCLUDED_TABLES

  profile = prompt.select('Which restore profile would you like to use?') do |menu|
    menu.choice profile_description(excluded['full'], extra, 'Full'), 'full'
    menu.choice profile_description(excluded['minimal'], extra, 'Minimal'), 'minimal'
  end

  custom_exclude = customize_minimal_exclusions(profile, prompt)

  if restore_source == :remote
    dump_method = 'backup'

    dump_method_choice = prompt.select('How would you like to download?') do |menu|
      menu.choice 'Standard (Heroku backup capture + download full dump)', 'backup'
      menu.choice 'pg:pull (pulls directly from Heroku DB, excludes tables at dump time - faster)', 'pg_pull'
    end
    dump_method = dump_method_choice

    run_remote_restore(profile, backup_option, dump_method, custom_exclude)
  else
    run_local_restore(profile, custom_exclude)
  end
end

def customize_minimal_exclusions(profile, prompt)
  return nil unless profile == 'minimal'
  return nil unless prompt.yes?('Would you like to customize which tables to exclude?', default: false)

  minimal_tables = HerokuCommands::EXCLUDED_TABLES['minimal']
  selected = prompt.multi_select('Select tables to exclude (uncheck to keep the data):',
                                 minimal_tables,
                                 default: (1..minimal_tables.length).to_a,
                                 per_page: minimal_tables.length)

  selected.empty? ? 'none' : selected.join(';')
end

def run_remote_restore(profile, backup_option, dump_method = 'backup', custom_exclude = nil)
  heroku_app_name = RadBin.get_heroku_app_name(:all)

  if dump_method == 'pg_pull'
    puts "Pulling from Heroku database with profile '#{profile}'"
    rake_args = "#{heroku_app_name},#{profile},,pg_pull,#{custom_exclude}"
  else
    backup_id = backup_option.is_a?(String) ? backup_option : RadBin.select_backup_id(heroku_app_name)

    puts "Cloning from remote Heroku backup with profile '#{profile}'"
    rake_args = "#{heroku_app_name},#{profile},#{backup_id},backup,#{custom_exclude}"
  end

  RadBin.system!("bundle exec rails \"heroku:clone_local[#{rake_args}]\"")
end

def run_local_restore(profile, custom_exclude = nil)
  prompt = TTY::Prompt.new
  backup_dir = "#{Dir.pwd}/heroku_backups"
  files = Dir.glob("#{backup_dir}/*.backup").reverse

  if files.empty?
    puts 'No backup files found in /heroku_backups.'
    exit(1)
  end

  display_names = files.map { |path| File.basename(path) }
  choice = prompt.select('Select a local backup file to restore:', display_names)
  selected_file = files[display_names.index(choice)]

  puts "Restoring from local file: #{selected_file}"
  RadBin.system!("bundle exec rails \"local:restore_from_backup[#{selected_file},#{profile},#{custom_exclude}]\"")
end

def run_default_clone
  heroku_app_name = RadBin.get_heroku_app_name(:all)
  puts "Proceeding with default clone_local for app: #{heroku_app_name}"
  RadBin.system!("bundle exec rails \"heroku:clone_local[#{heroku_app_name}]\"")
end

RadBin.rad_common_not_permitted!

options = {}
OptionParser.new { |opts|
  opts.banner = 'Usage: bin/clone_local [options]'

  opts.on('-i', '--interactive [BACKUP_ID]',
          'Interactive mode: choose between remote or local backup restore') do |backup_id|
    options[:interactive] = backup_id || true
  end

  opts.on('-h', '--help', 'Show this help message') do
    puts opts
    exit
  end
}.parse!

FileUtils.chdir Dir.pwd do
  if options[:interactive]
    run_interactive_clone(options[:interactive])
    exit
  end

  run_default_clone
end
