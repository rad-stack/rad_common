- if RadConfig.browser_notifications_enabled?
  .card.mb-3{ data: { controller: 'push-subscription' } }
    .card-header.bg-light
      %h5.mb-0
        %i.fa.fa-bell.me-2
        Browser Notifications
    .card-body
      %p.text-muted
        Browser notifications allow you to receive alerts even when you're not actively using this site.

      .browser-notification-status
        %template{ data: { 'push-subscription-target': 'grantedTemplate' } }
          .alert.alert-success.mb-0
            %i.fa.fa-check-circle.me-2
            Browser notifications are enabled.
            %button.btn.btn-sm.btn-outline-danger.ms-3{ type: 'button',
                                                        data: { action: 'click->push-subscription#unsubscribe' } }
              Disable

        %template{ data: { 'push-subscription-target': 'deniedTemplate' } }
          .alert.alert-warning.mb-0
            %i.fa.fa-exclamation-triangle.me-2
            Browser notifications are blocked. To enable them, update your browser settings for this site.

        %template{ data: { 'push-subscription-target': 'defaultTemplate' } }
          .alert.alert-info.mb-0.d-flex.align-items-center.justify-content-between
            %span
              %i.fa.fa-info-circle.me-2
              Click the button to enable browser notifications.
            %button.btn.btn-primary{ type: 'button',
                                     data: { action: 'click->push-subscription#requestPermission' } }
              %i.fa.fa-bell.me-1
              Enable Browser Notifications

        %template{ data: { 'push-subscription-target': 'unsupportedTemplate' } }
          .alert.alert-secondary.mb-0
            %i.fa.fa-info-circle.me-2
            Browser notifications are not supported in this browser.

        -# This div will be replaced with the appropriate template by JS
        #browser-notification-status-container{ data: { 'push-subscription-target': 'statusContainer' } }
          .text-muted
            %i.fa.fa-spinner.fa-spin.me-2
            Checking notification status...
