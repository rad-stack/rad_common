- can_create = policy(NotificationSetting.new).new?
- can_type = policy(NotificationType.new).update?

.card-body
  %table.table.table-bordered
    %tr
      - unless show_user
        %th Notification
      - if show_user
        %th User
      %th
        Enabled
        - if RadConfig.twilio_enabled?
          %p Email/SMS/Feed
        - else
          %p Email/Feed
        - if can_create
          .d-inline-flex.flex-column.mt-2.gap-1
            .d-flex.gap-1
              %button.btn.btn-sm.btn-success.select-all-settings.flex-fill{ data: { field: 'enabled' } }
                Enable All
              %button.btn.btn-sm.btn-danger.select-none-settings.flex-fill{ data: { field: 'enabled' } }
                Disable All
            .d-flex.gap-1
              %button.btn.btn-sm.btn-primary.select-all-settings.flex-fill{ data: { field: 'email' } }
                All Email
              %button.btn.btn-sm.btn-secondary.select-none-settings.flex-fill{ data: { field: 'email' } }
                No Email
            - if RadConfig.twilio_enabled?
              .d-flex.gap-1
                %button.btn.btn-sm.btn-primary.select-all-settings.flex-fill{ data: { field: 'sms' } }
                  All SMS
                %button.btn.btn-sm.btn-secondary.select-none-settings.flex-fill{ data: { field: 'sms' } }
                  No SMS
            .d-flex.gap-1
              %button.btn.btn-sm.btn-primary.select-all-settings.flex-fill{ data: { field: 'feed' } }
                All Feed
              %button.btn.btn-sm.btn-secondary.select-none-settings.flex-fill{ data: { field: 'feed' } }
                No Feed

    - settings.each do |record|
      :ruby
        setting_id_string = "#{record.notification_type.description.parameterize.underscore}_user_#{record.user_id}"
        collapse_id = "notification-options-#{setting_id_string}"
        updatable = can_create && policy(record).create?
      %tr{ class: table_row_style(record) }
        - unless show_user
          %td
            - if can_type
              = link_to record.notification_type, edit_notification_type_path(record.notification_type)
            - else
              = record.notification_type
        - if show_user
          %td= secured_link record.user
        %td.w-50
          = simple_form_for record,
                            url: notification_settings_path,
                            method: :post,
                            html: { class: 'dynamic-updater' } do |f|
            = rad_form_errors f
            .row
              .col-lg
                = f.input :enabled,
                          tooltip: 'Turn this notification on or off.',
                          disabled: !updatable,
                          input_html: { class: 'ays-ignore',
                                        id: "notification_setting_enabled_#{setting_id_string}",
                                        'data-bs-toggle': 'collapse', 'data-bs-target': "##{collapse_id}" }
            .row
              .col-lg-12{ id: collapse_id, class: record.enabled ? 'collapse show' : 'collapse' }
                .d-flex.gap-1.align-items-center.px-3.py-2.bg-light.border.rounded.shadow-sm#notification-settings
                  = f.input :email, tooltip: 'Enable email notifications.',
                                    input_html: { class: 'ays-ignore',
                                                  id: "notification_setting_email_#{setting_id_string}" },
                                    disabled: !record.notification_type.email_enabled? || !updatable

                  - if RadConfig.twilio_enabled?
                    = f.input :sms, tooltip: 'Enable SMS (text message) notifications.',
                                    input_html: { class: 'ays-ignore',
                                                  id: "notification_setting_sms_#{setting_id_string}" },
                                    disabled: !record.notification_type.sms_enabled? || !updatable

                  = f.input :feed,
                            tooltip: 'Show a red badge on the top right navigation when a notification occurs.',
                            input_html: { class: 'ays-ignore',
                                          id: "notification_setting_feed_#{setting_id_string}" },
                            disabled: !record.notification_type.feed_enabled? || !updatable

            = f.association :notification_type, as: :hidden
            = f.input :user_id, as: :hidden
